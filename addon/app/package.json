{
  "name": "receipt-printer-service",
  "version": "0.3.2",
  "description": "Render and print thermal receipts for Home Assistant",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "TEMPLATE_DIR=../../templates TRANSPORT=noop PRINT_ENABLED=false node --watch server.js",
    "check": "node --check server.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "express": "^4.21.2",
    "handlebars": "^4.7.8",
    "playwright-core": "^1.51.1",
    "pngjs": "^7.0.0"
  }
}
