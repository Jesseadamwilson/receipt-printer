{
  "name": "Receipt Printer Service",
  "version": "0.2.0",
  "slug": "receipt_printer",
  "description": "Preview-first receipt rendering + printing service for Home Assistant",
  "url": "https://github.com/Jesseadamwilson/receipt-printer",
  "arch": ["aarch64", "amd64", "armv7", "armhf", "i386"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:printer-pos",
  "ports": {
    "8099/tcp": 8099
  },
  "ports_description": {
    "8099/tcp": "Receipt printer API"
  },
  "map": ["config:rw", "share:rw"],
  "options": {
    "printer_host": "",
    "printer_port": 9100,
    "transport": "raw_tcp",
    "print_enabled": false,
    "paper_width_px": 576,
    "default_feed_lines": 3,
    "default_cut": true,
    "default_threshold": 180,
    "queue_timeout_ms": 20000,
    "queue_max_retries": 2,
    "template_dir": "/config/receipt-printer/templates",
    "agenda_include_header": true,
    "agenda_include_weather": true,
    "agenda_include_sleep": true,
    "agenda_include_events": true,
    "agenda_include_alerts": true,
    "agenda_include_notes": true,
    "agenda_include_footer": true
  },
  "schema": {
    "printer_host": "str?",
    "printer_port": "int(1,65535)",
    "transport": "list(raw_tcp|noop)",
    "print_enabled": "bool",
    "paper_width_px": "int(256,1200)",
    "default_feed_lines": "int(0,12)",
    "default_cut": "bool",
    "default_threshold": "int(1,255)",
    "queue_timeout_ms": "int(1000,120000)",
    "queue_max_retries": "int(0,5)",
    "template_dir": "str?",
    "agenda_include_header": "bool",
    "agenda_include_weather": "bool",
    "agenda_include_sleep": "bool",
    "agenda_include_events": "bool",
    "agenda_include_alerts": "bool",
    "agenda_include_notes": "bool",
    "agenda_include_footer": "bool"
  }
}
