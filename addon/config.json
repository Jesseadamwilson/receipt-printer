{
  "name": "Receipt Printer Spike",
  "version": "0.7.3",
  "slug": "receipt_printer",
  "description": "Template-rendered receipt printing API over raw TCP for Home Assistant",
  "url": "https://github.com/Jesseadamwilson/receipt-printer",
  "arch": ["aarch64", "amd64", "armv7", "armhf", "i386"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "homeassistant_api": true,
  "hassio_api": true,
  "ingress": true,
  "ingress_port": 8099,
  "panel_icon": "mdi:printer-pos",
  "ports": {
    "8099/tcp": 8099
  },
  "ports_description": {
    "8099/tcp": "Receipt printer API"
  },
  "map": ["config:rw"],
  "options": {
    "printer_host": "10.0.0.25",
    "printer_port": 9100,
    "printer_language": "star-prnt",
    "printer_model": "star-mc-print3",
    "printer_cut_mode": "full",
    "print_timeout_ms": 15000,
    "paper_width": 576,
    "queue_max_retries": 2,
    "queue_retry_delay_ms": 1000,
    "template_path": "/config/receipt-printer/templates/receipt.html",
    "template_message_path": "/config/receipt-printer/templates/message.html",
    "template_daily_agenda_path": "/config/receipt-printer/templates/daily-agenda.html",
    "custom_css_path": "/config/receipt-printer/templates/custom.css",
    "profile_store_path": "/config/receipt-printer/profiles.json",
    "ha_api_base_url": "http://supervisor/core/api",
    "ha_api_token": "",
    "agenda_calendar_entities": "",
    "agenda_weather_entity": "",
    "agenda_sleep_entity": "",
    "agenda_battery_entities": "",
    "agenda_alert_entities": "",
    "agenda_notes_entity": "",
    "agenda_section_order": "weather,sleep,events,battery,alerts,notes",
    "agenda_time_window_hours": 24,
    "agenda_include_header": true,
    "agenda_include_weather": true,
    "agenda_include_sleep": true,
    "agenda_include_events": true,
    "agenda_include_battery": true,
    "agenda_include_alerts": true,
    "agenda_include_notes": true,
    "agenda_include_footer": true
  },
  "schema": {
    "printer_host": "str",
    "printer_port": "int(1,65535)",
    "printer_language": "list(star-prnt|esc-pos)",
    "printer_model": "str?",
    "printer_cut_mode": "list(full|partial|none)",
    "print_timeout_ms": "int(1000,120000)",
    "paper_width": "int(256,1200)",
    "queue_max_retries": "int(0,5)",
    "queue_retry_delay_ms": "int(0,60000)",
    "template_path": "str?",
    "template_message_path": "str?",
    "template_daily_agenda_path": "str?",
    "custom_css_path": "str?",
    "profile_store_path": "str?",
    "ha_api_base_url": "str?",
    "ha_api_token": "str?",
    "agenda_calendar_entities": "str?",
    "agenda_weather_entity": "str?",
    "agenda_sleep_entity": "str?",
    "agenda_battery_entities": "str?",
    "agenda_alert_entities": "str?",
    "agenda_notes_entity": "str?",
    "agenda_section_order": "str?",
    "agenda_time_window_hours": "int(1,168)",
    "agenda_include_header": "bool",
    "agenda_include_weather": "bool",
    "agenda_include_sleep": "bool",
    "agenda_include_events": "bool",
    "agenda_include_battery": "bool",
    "agenda_include_alerts": "bool",
    "agenda_include_notes": "bool",
    "agenda_include_footer": "bool"
  }
}
